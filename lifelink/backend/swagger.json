    "/donors/search": {
      "get": {
        "operationId": "DonorsController_search",
        "summary": "Search donors by blood group, distance, city",
        "parameters": [
          {
            "name": "blood_group",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "A+",
                "A-",
                "B+",
                "B-",
                "O+",
                "O-",
                "AB+",
                "AB-"
              ],
              "type": "string"
            }
          },
          {
            "name": "radius",
            "required": false,
            "in": "query",
            "description": "Search radius in km",
            "schema": {
              "example": 10,
              "type": "number"
            }
          },
          {
            "name": "latitude",
            "required": false,
            "in": "query",
            "schema": {
              "example": 19.076,
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "required": false,
            "in": "query",
            "schema": {
              "example": 72.8777,
              "type": "number"
            }
          },
          {
            "name": "city",
            "required": false,
            "in": "query",
            "schema": {
              "example": "Mumbai",
              "type": "string"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "donors"
        ]
      }
    },
