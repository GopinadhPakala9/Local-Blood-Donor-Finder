  "info": {
    "title": "LifeLink API",
    "description": "LifeLink – Blood Donor Finder API Documentation",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "donors",
      "description": "Donor management"
    },
    {
      "name": "blood-requests",
      "description": "Blood request management"
    },
    {
      "name": "hospitals",
      "description": "Hospital management"
    },
    {
      "name": "blood-banks",
      "description": "Blood bank management"
    },
    {
      "name": "donations",
      "description": "Donation tracking"
    },
    {
      "name": "rewards",
      "description": "Rewards and gamification"
    },
    {
      "name": "notifications",
      "description": "Push notifications"
    },
    {
      "name": "admin",
      "description": "Admin panel"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SendOtpDto": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "example": "+919876543210 or user@example.com",
            "description": "Phone number (E.164) or email address"
          }
        },
        "required": [
          "identifier"
        ]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "example": "+919876543210 or user@example.com"
          },
          "otp": {
            "type": "string",
            "example": "123456"
          },
          "name": {
            "type": "string",
            "example": "Ravi Kumar"
          }
        },
        "required": [
          "identifier",
          "otp"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "example": "+919876543210 or user@example.com"
          },
          "password": {
            "type": "string",
            "example": "MyPassword@123"
          }
        },
        "required": [
          "identifier",
          "password"
        ]
      },
      "SetPasswordDto": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "example": "MyPassword@123"
          }
        },
        "required": [
          "password"
        ]
      },
      "GoogleLoginDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Google OAuth access token from client-side sign-in"
          }
        },
        "required": [
          "accessToken"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "blood_group": {
            "type": "string",
            "enum": [
              "A+",
              "A-",
              "B+",
              "B-",
              "O+",
              "O-",
              "AB+",
              "AB-"
            ]
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female",
              "other"
            ]
          },
          "dob": {
            "type": "string",
            "example": "1995-06-15"
          },
          "weight": {
            "type": "number"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          }
        }
      },
      "UpdateFcmTokenDto": {
        "type": "object",
        "properties": {
          "fcmToken": {
            "type": "string"
          }
        },
        "required": [
          "fcmToken"
        ]
      },
      "UpdateAvailabilityDto": {
        "type": "object",
        "properties": {
          "isAvailable": {
            "type": "boolean"
          }
        },
        "required": [
          "isAvailable"
        ]
      },
      "RegisterDonorDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "blood_group": {
            "type": "string",
            "enum": [
              "A+",
              "A-",
              "B+",
              "B-",
              "O+",
              "O-",
              "AB+",
              "AB-"
            ],
            "example": "O+"
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female",
              "other"
            ],
            "example": "male"
          },
          "dob": {
            "type": "string",
            "example": "1990-01-15"
          },
          "weight": {
            "type": "number",
            "example": 70,
            "description": "Weight in kg (min 45)"
          },
          "city": {
            "type": "string",
            "example": "Mumbai"
          },
          "state": {
            "type": "string",
            "example": "Maharashtra"
          },
          "latitude": {
            "type": "number",
            "example": 19.076
          },
          "longitude": {
            "type": "number",
            "example": 72.8777
          },
          "is_available": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "name",
          "blood_group",
          "gender",
          "dob",
          "weight",
          "city",
          "state"
        ]
      },
      "CreateBloodRequestDto": {
        "type": "object",
        "properties": {
          "patient_name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "blood_group": {
            "type": "string",
            "enum": [
              "A+",
              "A-",
              "B+",
              "B-",
              "O+",
              "O-",
              "AB+",
              "AB-"
            ],
            "example": "O+"
          },
          "units_required": {
            "type": "number",
            "example": 2,
            "description": "Number of units required"
          },
          "hospital_name": {
            "type": "string",
            "example": "Apollo Hospital"
          },
          "contact_number": {
            "type": "string",
            "example": "+919876543210"
          },
          "required_date": {
            "type": "string",
            "example": "2024-01-20"
          },
          "urgency": {
            "type": "string",
            "enum": [
              "Normal",
              "Urgent",
              "Critical"
            ],
            "default": "Normal"
          },
          "city": {
            "type": "string",
            "example": "Mumbai"
          },
          "latitude": {
            "type": "number",
            "example": 19.076
          },
          "longitude": {
            "type": "number",
            "example": 72.8777
          }
        },
        "required": [
          "patient_name",
          "blood_group",
          "units_required",
          "hospital_name",
          "contact_number",
          "urgency"
        ]
      },
      "CreateHospitalDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "license_number": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "city",
          "state"
        ]
      },
      "VerifyHospitalDto": {
        "type": "object",
        "properties": {}
      },
      "CreateBloodBankDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          }
        },
        "required": [
          "name",
          "city",
          "state"
        ]
      },
      "UpdateInventoryDto": {
        "type": "object",
        "properties": {
          "blood_group": {
            "type": "string",
            "enum": [
              "A+",
              "A-",
              "B+",
              "B-",
              "O+",
              "O-",
              "AB+",
              "AB-"
            ]
          },
          "available_units": {
            "type": "number"
          }
        },
        "required": [
          "blood_group",
          "available_units"
        ]
      },
      "LogDonationDto": {
        "type": "object",
        "properties": {
          "donated_on": {
            "type": "string",
            "example": "2024-01-15"
          },
          "units": {
            "type": "number",
            "example": 1
          },
          "blood_request_id": {
            "type": "string"
          }
        },
        "required": [
          "donated_on"
        ]
      }
    }
  }
}