<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>LifeLink</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>lifelink</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- URL Schemes (deep linking) -->
	<key>CFBundleURLTypes</key>
	<array>
		<!-- Deep link scheme -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>lifelink</string>
			</array>
		</dict>
		<!-- Google Sign-In: replace REVERSED_CLIENT_ID with the value from GoogleService-Info.plist -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>REVERSED_CLIENT_ID_FROM_GOOGLESERVICE_INFO_PLIST</string>
			</array>
		</dict>
	</array>

	<!-- Location Permissions -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>LifeLink needs your location to find blood donors and hospitals near you.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>LifeLink needs your location to show you nearby blood donors and emergency requests.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>LifeLink needs your location in the background to notify you of nearby emergencies.</string>

	<!-- Camera & Photo Library -->
	<key>NSCameraUsageDescription</key>
	<string>LifeLink uses the camera to update your profile photo.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>LifeLink accesses your photo library to set a profile picture.</string>

	<!-- Microphone (not used but required by some packages) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Microphone access is not used by LifeLink.</string>

	<!-- Contacts (for phone integration) -->
	<key>NSContactsUsageDescription</key>
	<string>LifeLink may access contacts to help you reach blood donors quickly.</string>

	<!-- Google Maps -->
	<key>NSLocationUsageDescription</key>
	<string>LifeLink needs your location to find nearby blood donors.</string>

	<!-- Push Notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>

	<!-- App Transport Security — allow all for dev, restrict for prod -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>

	<!-- Flutter -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
</dict>
</plist>
